# Server
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/medtrack_db?schema=public

# Auth
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRE=7d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=MedTrack <noreply@medtrack.com>

# Extraction mode
EXTRACTION_MODE=STRICT

# CORS
# Comma-separated list of allowed origins in production.
CORS_ORIGINS=https://your-frontend-domain.com
# Backward-compatible single origin fallback.
FRONTEND_URL=https://your-frontend-domain.com

# Firebase (set one of these)
# Option 1: full JSON in one env var
FIREBASE_SERVICE_ACCOUNT=
# Option 2: path to mounted JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=
